---
import Layout from "../layouts/Layout.astro";
import envelopIcon from "../assets/envelop.svg";
import pinIcon from "../assets/pin.svg";
import phoneIcon from "../assets/phone.svg";
import instagramIcon from "../assets/instagram.svg";
import facebookIcon from "../assets/facebook.svg";

const title = "Contact";
const description = "Contactez l'equipe du Flying Tap Fest";
---

<Layout title={title} description={description}>
	<section class="mx-auto w-full max-w-6xl space-y-14">
		<div class="mx-auto w-full max-w-3xl rounded-xl p-6 md:p-8">
			<h2 class="text-3xl font-extrabold text-[var(--orange-600)]">Nous ecrire</h2>
			<p class="mt-2 text-sm text-[var(--orange-800)]/80">Une question ? Envoyez-nous un message et nous vous repondrons rapidement.</p>

			<form class="mt-6 space-y-5" method="post" action="#">
				<div class="space-y-2">
					<label for="contact-name" class="block text-sm font-bold uppercase tracking-[0.06em] text-[var(--orange-700)]">Nom</label>
					<input id="contact-name" name="name" type="text" class="w-full rounded-lg border border-[var(--orange-700)]/25 bg-[var(--cream-50)] px-4 py-3 text-sm text-[var(--orange-800)] outline-none focus:border-[var(--orange-600)]" placeholder="Votre nom" />
				</div>

				<div class="space-y-2">
					<label for="contact-email" class="block text-sm font-bold uppercase tracking-[0.06em] text-[var(--orange-700)]">Email</label>
					<input id="contact-email" name="email" type="email" class="w-full rounded-lg border border-[var(--orange-700)]/25 bg-[var(--cream-50)] px-4 py-3 text-sm text-[var(--orange-800)] outline-none focus:border-[var(--orange-600)]" placeholder="vous@email.com" />
				</div>

				<div class="space-y-2">
					<label for="contact-message" class="block text-sm font-bold uppercase tracking-[0.06em] text-[var(--orange-700)]">Message</label>
					<textarea id="contact-message" name="message" rows="6" class="w-full rounded-lg border border-[var(--orange-700)]/25 bg-[var(--cream-50)] px-4 py-3 text-sm text-[var(--orange-800)] outline-none focus:border-[var(--orange-600)]" placeholder="Votre message"></textarea>
				</div>

				<button type="submit" class="inline-flex items-center rounded-md bg-[var(--orange-600)] px-5 py-3 text-sm font-bold text-[var(--cream-50)] transition-colors hover:bg-[var(--orange-700)]">
					Envoyer
				</button>
			</form>
		</div>

		<div class="space-y-10">
			<h2 class="text-center text-5xl font-extrabold uppercase tracking-[0.01em] text-[var(--orange-600)]">Informations de contact</h2>

			<div class="grid grid-cols-3 gap-3">
				<div class="rounded-xl p-6 text-center">
					<div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--orange-600)]/10 text-[var(--orange-600)]">
						<img src={envelopIcon.src} alt="" class="h-7 w-7" aria-hidden="true" />
					</div>
					<p class="text-xl font-bold text-[var(--orange-700)]">Email</p>
					<p class="mt-2 text-lg text-[var(--orange-800)]/90">contact@flyingtapfest.fr</p>
				</div>

				<div class="rounded-xl p-6 text-center">
					<div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--orange-600)]/10 text-[var(--orange-600)]">
						<img src={pinIcon.src} alt="" class="h-7 w-7" aria-hidden="true" />
					</div>
					<p class="text-xl font-bold text-[var(--orange-700)]">Adresse</p>
					<p class="mt-2 text-lg leading-relaxed text-[var(--orange-800)]/90">Parc du Pres-la-Rose<br/>25200 Montbeliard, France</p>
				</div>

				<div class="rounded-xl p-6 text-center">
					<div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--orange-600)]/10 text-[var(--orange-600)]">
						<img src={phoneIcon.src} alt="" class="h-7 w-7" aria-hidden="true" />
					</div>
					<p class="text-xl font-bold text-[var(--orange-700)]">Telephone</p>
					<p class="mt-2 text-lg text-[var(--orange-800)]/90">+33 3 84 00 00 00</p>
				</div>
			</div>

			<div class="text-center">
				<h3 class="text-4xl font-extrabold uppercase text-[var(--orange-600)]">Reseaux sociaux</h3>
				<div class="mt-6 flex items-center justify-center gap-6 text-[var(--orange-600)]">
					<a href="https://instagram.com" target="_blank" rel="noreferrer noopener" aria-label="Instagram" class="transition-transform hover:-translate-y-1">
						<img src={instagramIcon.src} alt="" class="h-12 w-12" aria-hidden="true" />
					</a>
					<a href="https://facebook.com" target="_blank" rel="noreferrer noopener" aria-label="Facebook" class="transition-transform hover:-translate-y-1">
						<img src={facebookIcon.src} alt="" class="h-12 w-12" aria-hidden="true" />
					</a>
				</div>
				<p class="mt-6 text-3xl text-[var(--orange-800)]/90">Au plaisir d'echanger avec vous.</p>
			</div>
		</div>
	</section>
</Layout>
