---
import Layout from "../../layouts/Layout.astro";
import { getArtisteById, getSceneById } from "../../js/backend.mjs";

const showId = Astro.params.id || "";

const dateFormatter = new Intl.DateTimeFormat("fr-FR", {
	timeZone: "Europe/Paris",
	day: "2-digit",
	month: "2-digit",
	year: "numeric",
});

const hourFormatter = new Intl.DateTimeFormat("fr-FR", {
	timeZone: "Europe/Paris",
	hour: "2-digit",
	minute: "2-digit",
});

type ArtisteRecord = {
	id: string;
	Nom?: string;
	Desc?: string;
	Date_Rep?: string;
	Scene?: string;
	IMG_Main?: string | string[];
	collectionId?: string;
	[key: string]: unknown;
};

type SceneRecord = {
	id: string;
	Nom?: string;
	[key: string]: unknown;
};

function getMainImageUrl(record: ArtisteRecord) {
	const mainRaw = record.IMG_Main;
	const fileName = Array.isArray(mainRaw) ? mainRaw[0] : mainRaw;

	if (!fileName || !record.collectionId || !record.id) {
		return null;
	}

	return `https://sae203tapdance.merlinhenry.fr/api/files/${record.collectionId}/${record.id}/${fileName}`;
}

let artiste: ArtisteRecord | null = null;
let scene: SceneRecord | null = null;

try {
	artiste = (await getArtisteById(showId)) as ArtisteRecord;
	if (artiste?.Scene) {
		scene = (await getSceneById(artiste.Scene)) as SceneRecord;
	}
} catch (error) {
	console.error("Erreur chargement show:", error);
	Astro.response.status = 404;
}

const title = artiste?.Nom ? `Show: ${artiste.Nom}` : "Show introuvable";
const description = artiste?.Nom ? `Details du show de ${artiste.Nom}` : "Show introuvable";

let dateLabel = "Date a confirmer";
let hourLabel = "Horaire a confirmer";

if (artiste?.Date_Rep) {
	const parsed = new Date(artiste.Date_Rep);
	if (!Number.isNaN(parsed.getTime())) {
		dateLabel = dateFormatter.format(parsed);
		hourLabel = hourFormatter.format(parsed);
	}
}
---

<Layout title={title} description={description}>
	<section class="mx-auto w-full max-w-5xl space-y-8">
		{artiste ? (
			<>
				<h2 class="text-center text-5xl font-extrabold uppercase tracking-[0.01em] text-[var(--orange-600)]">{artiste.Nom}</h2>

				<div class="grid gap-6 md:grid-cols-[1.3fr_1fr]">
					{getMainImageUrl(artiste) ? <img src={getMainImageUrl(artiste)} alt={`Image du show ${artiste.Nom}`} class="h-[340px] w-full rounded-xl object-cover" /> : null}

					<div class="space-y-3 rounded-xl bg-white p-5 shadow-[0_8px_22px_rgba(0,0,0,0.08)]">
						<h3 class="text-xl font-bold text-[var(--orange-700)]">Infos du show</h3>
						<p class="text-sm font-semibold uppercase tracking-[0.06em] text-[var(--orange-800)]">{dateLabel}</p>
						<p class="text-sm font-semibold uppercase tracking-[0.06em] text-[var(--orange-800)]">{hourLabel}</p>
						<p class="text-sm font-semibold uppercase tracking-[0.06em] text-[var(--orange-800)]">{scene?.Nom || "Scene a confirmer"}</p>
						<a href={`/artistes/${artiste.id}`} class="inline-flex items-center rounded-md bg-[var(--orange-600)] px-4 py-2 text-sm font-bold text-[var(--cream-50)] no-underline transition-colors hover:bg-[var(--orange-700)]">
							Voir la fiche artiste
						</a>
					</div>
				</div>

				<div class="space-y-4 rounded-xl bg-white p-6 shadow-[0_8px_22px_rgba(0,0,0,0.08)]">
					<h3 class="text-2xl font-bold text-[var(--orange-700)]">Resume</h3>
					<div class="space-y-3 text-base leading-relaxed text-[var(--orange-800)]/90 [&_p]:m-0 [&_strong]:font-bold" set:html={artiste.Desc || "Aucune description disponible."} />
				</div>
			</>
		) : null}
	</section>
</Layout>
